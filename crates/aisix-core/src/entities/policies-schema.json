{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "when", "actions"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "priority": {
      "type": "integer",
      "default": 0
    },
    "when": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "config"],
            "properties": {
              "type": {
                "const": "guardrail"
              },
              "config": {
                "type": "object",
                "additionalProperties": false,
                "required": ["guardrail_ids"],
                "properties": {
                  "stages": {
                    "type": "array",
                    "default": ["input", "output"],
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "enum": ["input", "output"]
                    }
                  },
                  "guardrail_ids": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        ]
      }
    }
  }
}
